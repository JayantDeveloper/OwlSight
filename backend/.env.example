BIRDEYE_API_KEY=your_key_here
COINGECKO_API_KEY=your_key_here
# Tier: "demo" (free, api.coingecko.com) or "pro" (paid, pro-api.coingecko.com)
COINGECKO_API_TIER=pro
COINGECKO_BASE_URL=https://pro-api.coingecko.com/api/v3
MARKET_DATA_PROVIDER=coingecko
HUMMINGBOT_ENABLED=true
HUMMINGBOT_API_URL=http://localhost:15888
HUMMINGBOT_INSTANCE_NAME=paper-demo
HUMMINGBOT_PAPER_TRADE=true
EXECUTION_MODE=paper_hummingbot
# Set to true to simulate Hummingbot as connected for demo/screenshots (no Hummingbot required)
DEMO_FORCE_HB_CONNECTED=false
CACHE_TTL_SECONDS=20
# Local:
FRONTEND_ORIGIN=http://localhost:3000
# Production: set to your Vercel URL in the Render dashboard
# FRONTEND_ORIGIN=https://your-app.vercel.app
