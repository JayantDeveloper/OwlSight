generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  wallets          LinkedWallet[]
  executionConn    ExecutionConnection?
  savedSimulations SavedSimulation[]
  executionRecords ExecutionRecord[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LinkedWallet {
  id         String   @id @default(cuid())
  userId     String
  ecosystem  String   // "solana" | "evm"
  address    String
  chainId    Int?     // EVM chain id (null for Solana)
  network    String?  // "mainnet" | "devnet" etc.
  walletType String?  // "phantom" | "metamask" | "walletconnect" etc.
  label      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ecosystem, address])
}

model ExecutionConnection {
  id            String   @id @default(cuid())
  userId        String   @unique
  mode          String   @default("mock") // "mock" | "paper" | "live"
  hummingbotUrl String?
  status        String   @default("disconnected") // "disconnected" | "connecting" | "connected" | "error"
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedSimulation {
  id                        String   @id @default(cuid())
  userId                    String
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  opportunityId             String
  assetSymbol               String
  buyChain                  String
  buyVenue                  String
  sellChain                 String
  sellVenue                 String
  bridgeName                String
  notionalUsd               Float
  grossSpreadBps            Float
  expectedNetProfitUsd      Float
  confidenceScore           Float
  estimatedFeesUsd          Float
  estimatedSlippageBps      Float
  estimatedBridgeLatencySec Float
  approvalStage             String   // "approved" | "rejected"
  approvalReason            String?
  monteCarlo                String?  // JSON: MonteCarloResult
  costBreakdown             String?  // JSON: CostBreakdown
  label                     String?
  notes                     String?
  pinned                    Boolean  @default(false)
  savedAt                   DateTime @default(now())

  executions                ExecutionRecord[]

  @@index([userId, savedAt])
}

model ExecutionRecord {
  id                     String           @id @default(cuid())
  userId                 String
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulationId           String?
  simulation             SavedSimulation? @relation(fields: [simulationId], references: [id])

  executionId            String
  requestId              String?
  opportunityId          String
  assetSymbol            String
  buyChain               String
  sellChain              String
  bridgeName             String
  notionalUsd            Float
  expectedNetProfitUsd   Float
  confidenceScore        Float
  executionModeRequested String
  executionModeUsed      String
  status                 String   // "completed" | "rejected" | "fallback"
  fallbackReason         String?
  rejectionReason        String?
  timeline               String?  // JSON: TimelineEvent[]

  startedAt              DateTime  @default(now())
  completedAt            DateTime?

  @@index([userId, startedAt])
}
